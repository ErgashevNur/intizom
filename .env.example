# ── Telegram ─────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_IDS=123456789,987654321
MINIAPP_URL=https://your-domain.com

# ── Database ──────────────────────────────────────────────────────────
# Docker ichida DB_HOST avtomatik "postgres" ga o'zgartiriladi
DB_HOST=localhost
DB_PORT=5432
DB_USER=intizom
DB_PASSWORD=strong_password_here
DB_NAME=intizom
# DB_SYNC — faqat lokal dev uchun true, production'da false!
DB_SYNC=false

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── Admin panel ───────────────────────────────────────────────────────
ADMIN_USERNAME=intizom
ADMIN_PASSWORD=strong_admin_password_here

# ── App ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS (production da domeningizni ko'rsating) ─────────────────────
# ALLOWED_ORIGIN=https://your-domain.com

# ── Product ───────────────────────────────────────────────────────────
PRODUCT_PRICE=49000
